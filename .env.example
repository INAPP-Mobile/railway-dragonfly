# Dragonfly - Railway Template Environment Variables
# Redis-compatible cache server

# === Connection ===

# Port Dragonfly listens on internally (Redis default)
# Note: Railway sets PORT env var; this is the internal port
DRAGONFLY_PORT=6379

# Require authentication on connection
DRAGONFLY_REQUIREPASS=

# === Memory Management ===

# Maximum memory limit (e.g., "1gb", "500mb")
DRAGONFLY_MAXMEMORY=

# Eviction policy when maxmemory reached (allkeys-lfu, volatile-lru, etc.)
DRAGONFLY_MAXMEMORY_POLICY=

# === Persistence ===

# Enable AOF persistence (on/off)
DRAGONFLY_AOF_ENCRYPTION=off

# === Admin ===

# Enable admin API endpoint
DRAGONFLY_ADMIN_PORT=

# Admin authentication token
DRAGONFLY_ADMIN_TOKEN=

# === Logging ===

# Log level: debug, info, warning, error, fatal
DRAGONFLY_LOG_LEVEL=warning
